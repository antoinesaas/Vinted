{
  "expo": {
    "name": "Stock.01",
    "slug": "stock01",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stock01",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser Stock.01 à accéder à vos photos.",
          "cameraPermission": "Autoriser Stock.01 à utiliser l'appareil photo."
        }
      ],
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
